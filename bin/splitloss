#!/usr/bin/env bash
# splitloss — compare gateway vs WAN loss over a concurrent ping window
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/netpack.sh
source "${ROOT}/lib/netpack.sh"
# shellcheck source=../lib/netpack/parsers.sh
source "${ROOT}/lib/netpack/parsers.sh"

T=60
WAN=1.1.1.1
DIR=""
KEEP_LOGS=0

usage() {
  cat <<'EOF'
splitloss — ping default gateway and a WAN target concurrently, then compare loss.

Localizes fault domain:
  gateway lossy                 -> access layer
  gateway clean, WAN lossy      -> uplink / path beyond the gateway
  both clean                    -> not indicated in this window

Also reports rtt min/avg/max/mdev per target (latency and jitter evidence;
compare an idle run against a run under planned load to show bufferbloat).
Runs of 120s or longer include a loss timeline: any 60s interval with loss is
listed with its wall-clock start, for correlating with incident reports.

Usage:
  splitloss [-t SECONDS] [-w WAN_TARGET] [-d DIR]

Options:
  -t SECONDS       Test duration (default: 60)
  -w WAN_TARGET    WAN ICMP target (default: 1.1.1.1)
  -d DIR           Keep logs in DIR (timestamped filenames; created if needed)
  -h, --help       Show this help

Without -d, logs are written under a private temp directory and removed on exit
after the summary is printed. Use -d to retain logs for timeline correlation.

Exit codes:
  0  both targets clean (<=1% loss)
  1  usage, dependency, or probe failure
  2  gateway loss (>1%)
  3  gateway clean, WAN loss (>1%)
EOF
}

if [[ "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

while getopts ":t:w:d:h" opt; do
  case "$opt" in
    t) T=$OPTARG ;;
    w) WAN=$OPTARG ;;
    d) DIR=$OPTARG; KEEP_LOGS=1 ;;
    h) usage; exit 0 ;;
    *) usage >&2; exit 1 ;;
  esac
done

require_uint duration "$T" 1
require_cmd ping ip

GW="$(default_gateway)"
[[ -n "$GW" ]] || die "no default gateway"

if [[ "$KEEP_LOGS" -eq 1 ]]; then
  mkdir -p "$DIR"
  chmod 700 "$DIR" 2>/dev/null || true
else
  DIR="$(private_tmpdir splitloss)"
fi

# Per-run filenames so repeat runs into the same -d DIR never clobber evidence.
STAMP="$(date +%Y%m%d-%H%M%S)"
LOG_GW="${DIR}/gw-${STAMP}.log"
LOG_WAN="${DIR}/wan-${STAMP}.log"

cleanup() {
  if [[ "${CLEAN_TMP:-0}" -eq 1 && "$KEEP_LOGS" -eq 0 && -n "${DIR:-}" && -d "$DIR" ]]; then
    rm -rf "$DIR"
  fi
}
trap cleanup EXIT

header splitloss
echo "gateway: ${GW}  wan: ${WAN}  duration: ${T}s"
# Wall-clock base for the loss timeline: seq N was sent ~N-1 seconds after this.
START_EPOCH="$(date +%s)"
set +e
ping -D -i 1 -w "$T" "$GW"  >"$LOG_GW"  2>&1 &
P1=$!
ping -D -i 1 -w "$T" "$WAN" >"$LOG_WAN" 2>&1 &
P2=$!
wait "$P1"
RC1=$?
wait "$P2"
RC2=$?
set -e

# ping returns 1 when some packets are lost but the run completed; 2+ is error.
if [[ ! -s "$LOG_GW" || ! -s "$LOG_WAN" ]]; then
  echo "logs retained: ${DIR}" >&2
  die "ping produced empty logs (check permissions and connectivity)"
fi
if (( RC1 >= 2 || RC2 >= 2 )); then
  echo "logs retained: ${DIR}" >&2
  die "ping failed (gateway exit ${RC1}, wan exit ${RC2})"
fi

gl="$(loss_pct "$LOG_GW")" || {
  echo "logs retained: ${DIR}" >&2
  die "could not parse gateway ping summary in ${LOG_GW}"
}
wl="$(loss_pct "$LOG_WAN")" || {
  echo "logs retained: ${DIR}" >&2
  die "could not parse WAN ping summary in ${LOG_WAN}"
}

# "label (host): X% packet loss  rtt min/avg/max/mdev a/b/c/d ms" — rtt is
# omitted when the log has no summary (100% loss).
print_target() {
  local label=$1 host=$2 loss=$3 log=$4
  local stats rmin ravg rmax rmdev extra=""
  if stats="$(rtt_stats "$log")"; then
    IFS=$'\t' read -r rmin ravg rmax rmdev <<<"$stats"
    extra="  rtt min/avg/max/mdev ${rmin}/${ravg}/${rmax}/${rmdev} ms"
  fi
  printf '%-7s (%s): %s packet loss%s\n' "$label" "$host" "$(color_loss_pct "$loss")" "$extra"
}

bucket_clock() {
  local epoch=$((START_EPOCH + $1))
  # GNU date on the Debian target; -r fallback keeps dev boxes working.
  date -d "@${epoch}" +%H:%M:%S 2>/dev/null || date -r "$epoch" +%H:%M:%S
}

print_timeline() {
  local label=$1 log=$2
  local rows rc=0 off lost expect pct
  # bucket_loss exits non-zero on an unusable log; do not report that as clean.
  rows="$(bucket_loss "$log" 60)" || rc=$?
  if (( rc != 0 )); then
    echo "  ${label}: $(color_status warn "timeline unavailable (log not parseable)")"
    return 0
  fi
  if [[ -z "$rows" ]]; then
    echo "  ${label}: $(color_status ok "no lossy intervals")"
    return 0
  fi
  echo "  ${label}:"
  while IFS=$'\t' read -r off lost expect; do
    [[ -n "$off" ]] || continue
    pct="$(awk -v l="$lost" -v e="$expect" 'BEGIN { printf "%.1f", e ? l * 100 / e : 0 }')"
    printf '    %s  %s\n' "$(bucket_clock "$off")" \
      "$(color_status bad "${lost}/${expect} lost (${pct}%)")"
  done <<<"$rows"
}

print_target gateway "$GW" "$gl" "$LOG_GW"
print_target wan "$WAN" "$wl" "$LOG_WAN"

# For long runs, show when the loss happened, not just how much.
if (( T >= 120 )); then
  section "loss timeline (60s intervals, lossy only)"
  print_timeline gateway "$LOG_GW"
  print_timeline wan "$LOG_WAN"
  echo
fi

if [[ "$KEEP_LOGS" -eq 1 ]]; then
  echo "logs: ${LOG_GW} ${LOG_WAN}"
else
  echo "logs: discarded after summary (pass -d DIR to retain)"
fi

# Enable temp cleanup only for successful interpretation paths.
CLEAN_TMP=1

finish() { echo "finished: $(timestamp_local)"; }

if awk -v p="$gl" 'BEGIN { exit !(p > 1) }'; then
  verdict "loss to gateway indicates an access-layer problem." \
    "Inspect local switch/AP, cabling, and the gateway path."
  finish
  exit 2
elif awk -v p="$wl" 'BEGIN { exit !(p > 1) }'; then
  verdict "gateway is clean; WAN path shows loss." \
    "Inspect uplink, venue circuit, and upstream path evidence."
  finish
  exit 3
else
  verdict "both targets were clean during this window." \
    "If the symptom was active, check application, server, or DNS layers."
  finish
  exit 0
fi
