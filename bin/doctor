#!/usr/bin/env bash
# doctor — check netpack dependencies and readiness
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/netpack.sh
source "${ROOT}/lib/netpack.sh"

usage() {
  cat <<'EOF'
doctor — check netpack dependencies and tool readiness.

Read-only. Does not require root. Reports which tools need sudo at run time.

Usage:
  doctor

Options:
  -h, --help    Show this help

Exit codes:
  0  all required commands for core tools are present
  1  usage error
  2  one or more required commands missing
EOF
}

if [[ "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

while getopts ":h" opt; do
  case "$opt" in
    h) usage; exit 0 ;;
    *) usage >&2; exit 1 ;;
  esac
done

have() {
  command -v "$1" >/dev/null 2>&1
}

check_cmd() {
  local name=$1
  if have "$name"; then
    printf '  %-14s OK\n' "$name"
    return 0
  fi
  printf '  %-14s MISSING\n' "$name"
  return 1
}

check_optional() {
  local name=$1
  if have "$name"; then
    printf '  %-14s OK\n' "$name"
  else
    printf '  %-14s absent (optional)\n' "$name"
  fi
}

MISSING=0

header doctor
echo "root: $(netpack_root)"
echo "bin:  $(netpack_bin)"
echo "user: $(id -un) (uid $(id -u))"
if [[ "$(id -u)" -eq 0 ]]; then
  echo "note: running as root (not required for doctor)"
fi
echo

echo "=== launcher ==="
if [[ -x "$(netpack_bin)/netpack" ]] && [[ -e "$(netpack_bin)/npk" ]]; then
  echo "  netpack/npk   OK"
else
  echo "  netpack/npk   MISSING or not executable"
  MISSING=$((MISSING + 1))
fi
echo

echo "=== shared commands ==="
for c in ip ping dig awk sort; do
  check_cmd "$c" || MISSING=$((MISSING + 1))
done
echo

echo "=== per-tool requirements ==="

tool_header() {
  printf '%s (sudo: %s)\n' "$1" "$2"
}

tool_header "dhcpprobe" "yes"
check_cmd python3 || MISSING=$((MISSING + 1))
if have python3 && python3 -c 'import scapy' 2>/dev/null; then
  printf '  %-14s OK\n' "scapy"
else
  printf '  %-14s MISSING\n' "scapy"
  MISSING=$((MISSING + 1))
fi
echo

tool_header "linkstat" "no"
check_cmd ip || MISSING=$((MISSING + 1))
check_optional ethtool
check_optional iw
echo

tool_header "segscan" "yes for arp-scan / often for LLDP"
check_cmd ip || MISSING=$((MISSING + 1))
check_cmd ping || MISSING=$((MISSING + 1))
check_optional arp-scan
check_optional lldpcli
echo

tool_header "splitloss" "no"
check_cmd ping || MISSING=$((MISSING + 1))
check_cmd ip || MISSING=$((MISSING + 1))
echo

tool_header "dnscheck" "no"
check_cmd dig || MISSING=$((MISSING + 1))
echo

tool_header "mtucheck" "no"
check_cmd ping || MISSING=$((MISSING + 1))
check_cmd ip || MISSING=$((MISSING + 1))
check_optional tracepath
echo

tool_header "path3" "yes"
check_cmd mtr || MISSING=$((MISSING + 1))
check_cmd awk || MISSING=$((MISSING + 1))
echo

tool_header "udp-loss" "no"
check_cmd dig || MISSING=$((MISSING + 1))
echo

tool_header "ringcap" "yes"
check_cmd tcpdump || MISSING=$((MISSING + 1))
echo

tool_header "testsrv" "yes when modifying nft sets"
check_cmd iperf3 || MISSING=$((MISSING + 1))
check_optional nft
echo

tool_header "testcli" "no"
check_cmd iperf3 || MISSING=$((MISSING + 1))
echo

echo "--"
if (( MISSING > 0 )); then
  verdict "${MISSING} required dependency check(s) failed." \
    "Install missing packages (see README) and re-run doctor."
  echo "finished: $(timestamp_local)"
  exit 2
fi
verdict "required dependencies look present." \
  "Tools that need root still require sudo at run time."
echo "finished: $(timestamp_local)"
exit 0
