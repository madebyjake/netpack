#!/usr/bin/env bash
# path3 — compare mtr over ICMP, UDP, and TCP
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/netpack.sh
source "${ROOT}/lib/netpack.sh"
# shellcheck source=../lib/netpack/parsers.sh
source "${ROOT}/lib/netpack/parsers.sh"

COUNT=50
PORT=443
TARGET=""

usage() {
  cat <<'EOF'
path3 — run mtr against a target in ICMP, UDP, and TCP modes.

Compares final-hop loss across protocols. Probe volume is COUNT x 3 modes.
The UDP mode sweeps destination ports and the TCP mode sends repeated SYNs,
which firewalls and IDS may flag as a port scan; probe only networks you are
authorized to test.
Tries unprivileged first; if a mode fails (common without CAP_NET_RAW on
UDP/TCP), re-run with sudo.

Usage:
  path3 [-c COUNT] [-p TCP_PORT] TARGET

Options:
  -c COUNT      Probes per mode (default: 50)
  -p TCP_PORT   TCP destination port (default: 443)
  -h, --help    Show this help

Notes:
  Prefer loss that appears at the final hop and is consistent across protocols.
  Intermediate-only loss is often control-plane deprioritization, not forwarding loss.

Exit codes:
  0  all three modes produced usable reports
  1  usage, dependency, permission, or mode failure
EOF
}

if [[ "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

while getopts ":c:p:h" opt; do
  case "$opt" in
    c) COUNT=$OPTARG ;;
    p) PORT=$OPTARG ;;
    h) usage; exit 0 ;;
    *) usage >&2; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

TARGET=${1:-}
[[ -n "$TARGET" ]] || { usage >&2; exit 1; }
require_uint count "$COUNT" 1
require_uint port "$PORT" 1 65535
require_cmd mtr awk

header path3
echo "target: ${TARGET}  count: ${COUNT}  tcp_port: ${PORT}"
echo

DIR="$(private_tmpdir path3)"
cleanup() { rm -rf "$DIR"; }
trap cleanup EXIT

FAILED_MODES=0

run_mode() {
  local label=$1
  shift
  local out="${DIR}/${label}.txt"
  echo "=== ${label} (${COUNT} probes) ==="
  if ! mtr -rwb -c "$COUNT" "$@" "$TARGET" | tee "$out"; then
    echo "error: mtr ${label} exited non-zero" >&2
    FAILED_MODES=$((FAILED_MODES + 1))
  elif [[ ! -s "$out" ]]; then
    echo "error: mtr ${label} produced no output" >&2
    FAILED_MODES=$((FAILED_MODES + 1))
  elif ! grep -q '%' "$out"; then
    echo "error: mtr ${label} output missing loss columns (unusable report)" >&2
    FAILED_MODES=$((FAILED_MODES + 1))
  fi
  echo
}

run_mode icmp
run_mode udp -u
run_mode tcp -T -P "$PORT"

echo "=== final-hop summary ==="
printf '%-5s %-40s %-10s %s\n' "mode" "host" "loss" "avg"
for m in icmp udp tcp; do
  f="${DIR}/${m}.txt"
  if [[ ! -s "$f" ]]; then
    printf '%-5s %-40s %-10s %s\n' "$m" "-" "$(color_status bad "-")" "-"
    continue
  fi
  IFS=$'\t' read -r host loss avg <<<"$(summarize_final "$f")"
  loss_disp="${loss:--}"
  if [[ "$loss_disp" != "-" ]]; then
    # summarize_final returns e.g. 4.0%; strip % for threshold helper.
    loss_num="${loss_disp%%%}"
    loss_disp="$(color_loss_pct "$loss_num")"
  fi
  printf '%-5s %-40s %-10s %s\n' "$m" "${host:--}" "$loss_disp" "${avg:--}"
done

if (( FAILED_MODES > 0 )); then
  if [[ "$(id -u)" -ne 0 ]]; then
    verdict "${FAILED_MODES} mtr mode(s) failed." \
      "Re-run with sudo (CAP_NET_RAW may be required)."
  else
    verdict "${FAILED_MODES} mtr mode(s) failed or produced unusable output."
  fi
  echo "finished: $(timestamp_local)"
  exit 1
fi
verdict "all three modes produced usable reports." \
  "Prefer final-hop loss corroborated across protocols; intermediate-only loss is often control-plane deprioritization."
echo "finished: $(timestamp_local)"
