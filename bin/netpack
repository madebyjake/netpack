#!/usr/bin/env bash
# netpack — launcher for network field tools
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Resolve symlinks when installed on PATH
if command -v readlink >/dev/null 2>&1; then
  if resolved="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null)"; then
    ROOT="$(cd "$(dirname "$resolved")" && pwd)"
  fi
fi

TOOLS=(
  dhcpprobe
  linkstat
  segscan
  wifiscan
  discover
  splitloss
  dnscheck
  webcheck
  portcheck
  mtucheck
  path3
  udp-loss
  mcastcheck
  ringcap
  testsrv
  testcli
  doctor
)

describe() {
  case "$1" in
    doctor)    echo "Dependency and readiness checks" ;;
    dhcpprobe) echo "DHCP servers on the local segment" ;;
    linkstat)  echo "Link counters; physical vs congestion signals" ;;
    segscan)   echo "Segment inventory (LLDP, gateway, ARP)" ;;
    wifiscan)  echo "Wi-Fi AP survey and channel usage" ;;
    discover)  echo "SSDP/mDNS service discovery" ;;
    splitloss) echo "Concurrent gateway vs WAN loss comparison" ;;
    dnscheck)  echo "Configured vs public DNS resolver comparison" ;;
    webcheck)  echo "Captive portal / HTTP + TLS interception check" ;;
    portcheck) echo "TCP service reachability by port" ;;
    mtucheck)  echo "Path MTU probe to gateway and WAN" ;;
    path3)     echo "mtr over ICMP, UDP, and TCP" ;;
    udp-loss)  echo "UDP loss via DNS queries with real replies" ;;
    mcastcheck) echo "Multicast delivery check (Dante/NDI paths)" ;;
    ringcap)   echo "Rotating packet capture ring buffer" ;;
    testsrv)   echo "iperf3 server with timed firewall open" ;;
    testcli)   echo "iperf3 client companion to testsrv" ;;
    *)         echo "" ;;
  esac
}

# Tools that require (or commonly require) root; tagged in menu and list.
sudo_tag() {
  case "$1" in
    dhcpprobe|segscan|wifiscan|path3|ringcap|testsrv) echo "[sudo]" ;;
    *) echo "" ;;
  esac
}

# Tools that generate network activity; tagged in menu and list.
# [warn] = significant load or active probing (may look like recon/intrusion).
# [note] = lighter diagnostic traffic.
impact_tag() {
  case "$1" in
    segscan|path3|testsrv|testcli) echo "[warn]" ;;
    dhcpprobe|wifiscan|discover|splitloss|udp-loss|mtucheck|portcheck|mcastcheck) echo "[note]" ;;
    *) echo "" ;;
  esac
}

# Tools that cannot do anything useful without root (subset of sudo_tag).
needs_root() {
  case "$1" in
    dhcpprobe|wifiscan|ringcap) return 0 ;;
    *) return 1 ;;
  esac
}

# Set to (sudo) by the menu flow; empty for direct invocation.
RUN_PREFIX=()

netpack_version() {
  local init="${ROOT}/../lib/netpack/__init__.py"
  if [[ -f "$init" ]]; then
    sed -n 's/^__version__ = "\(.*\)"/\1/p' "$init" | head -1
  else
    echo "0.1.0"
  fi
}

usage() {
  local me t
  me="$(basename "${BASH_SOURCE[0]}")"
  cat <<EOF
netpack — network field tools

Usage:
  ${me}                 Interactive menu
  ${me} list            List tools
  ${me} help            Show this help
  ${me} --version       Print version
  ${me} <tool> [args]   Run a tool (arguments pass through)

Also available as: netpack | npk

Tools:
EOF
  for t in "${TOOLS[@]}"; do
    printf "  %-10s  %-6s %-9s  %s\n" "$t" "$(sudo_tag "$t")" "$(impact_tag "$t")" "$(describe "$t")"
  done
  cat <<'EOF'

[sudo]    marks tools that need root for some or all operations.
[note]    marks tools that generate light diagnostic traffic.
[warn]    marks tools with significant load or active probing
          (may look like recon on a third-party network) — planned tests only.

Options:
  -h, --help, help     Show this help
  -V, --version        Print version
  list, ls             List tools

Tools are also available directly from this directory when it is on PATH.
EOF
}

list_tools() {
  local t st it c_tag
  local c_amber='' c_bold='' c_note='' c_warn='' c_off=''
  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    c_amber=$'\033[38;5;214m'
    c_bold=$'\033[1m'
    c_note=$'\033[38;5;214m'
    c_warn=$'\033[31m'
    c_off=$'\033[0m'
  fi
  printf '%snetpack (npk)   v%s%s\n' "$c_amber" "$(netpack_version)" "$c_off"
  echo
  for t in "${TOOLS[@]}"; do
    st="$(sudo_tag "$t")"
    it="$(impact_tag "$t")"
    c_tag=$c_note
    [[ "$it" == "[warn]" ]] && c_tag=$c_warn
    printf "  %s%-10s%s  %-6s %s%-6s%s    %s\n" \
      "$c_bold" "$t" "$c_off" \
      "$st" \
      "$c_tag" "$it" "$c_off" \
      "$(describe "$t")"
  done
  echo
  printf '  [sudo]    needs root\n'
  printf '  %s[note]%s    light diagnostic traffic\n' "$c_note" "$c_off"
  printf '  %s[warn]%s    significant load or active probing — planned tests only\n' "$c_warn" "$c_off"
}

# Prompt for required args when launching from the interactive menu.
menu_args_for() {
  local name=$1
  local val p
  case "$name" in
    portcheck)
      printf "HOST (required): " >&2
      if ! read -r val; then
        echo >&2
        exit 1
      fi
      [[ -n "$val" ]] || { echo "error: HOST required" >&2; exit 1; }
      printf '%s\n' "$val"
      printf "PORT(S), space-separated (required): " >&2
      if ! read -r val; then
        echo >&2
        exit 1
      fi
      [[ -n "$val" ]] || { echo "error: PORT required" >&2; exit 1; }
      for p in $val; do
        printf '%s\n' "$p"
      done
      ;;
    path3)
      printf "TARGET (required): " >&2
      if ! read -r val; then
        echo >&2
        exit 1
      fi
      [[ -n "$val" ]] || { echo "error: TARGET required" >&2; exit 1; }
      printf '%s\n' "$val"
      ;;
    ringcap)
      printf "Output directory -d DIR (required): " >&2
      if ! read -r val; then
        echo >&2
        exit 1
      fi
      [[ -n "$val" ]] || { echo "error: -d DIR required" >&2; exit 1; }
      printf -- '%s\n' -d "$val"
      ;;
    testcli)
      printf "HOST (required): " >&2
      if ! read -r val; then
        echo >&2
        exit 1
      fi
      [[ -n "$val" ]] || { echo "error: HOST required" >&2; exit 1; }
      printf '%s\n' "$val"
      ;;
  esac
}

run_tool() {
  local name=$1
  shift
  local path="${ROOT}/${name}"
  if [[ ! -x "$path" ]]; then
    echo "error: tool not found or not executable: ${name}" >&2
    echo "hint: run 'netpack list'" >&2
    exit 1
  fi
  exec "${RUN_PREFIX[@]+"${RUN_PREFIX[@]}"}" "$path" "$@"
}

run_tool_from_menu() {
  local name=$1
  local -a args=()
  local line ans
  if [[ -n "$(sudo_tag "$name")" && "$(id -u)" -ne 0 ]] \
      && command -v sudo >/dev/null 2>&1; then
    if needs_root "$name"; then
      echo "  ${name} requires root; using sudo" >&2
      RUN_PREFIX=(sudo)
    else
      printf "  %s uses root for full results; run with sudo? [Y/n]: " "$name" >&2
      if ! read -r ans; then
        echo >&2
        exit 1
      fi
      case "$ans" in
        n|N|no|NO) ;;
        *) RUN_PREFIX=(sudo) ;;
      esac
    fi
  fi
  # Command substitution (not process substitution) so an exit 1 inside
  # menu_args_for aborts the launch instead of running the tool with no args.
  local out
  if ! out="$(menu_args_for "$name")"; then
    exit 1
  fi
  while IFS= read -r line; do
    [[ -n "$line" ]] && args+=("$line")
  done <<<"$out"
  run_tool "$name" "${args[@]+"${args[@]}"}"
}

menu() {
  local i=1 t sel st it c_tag
  local c_amber='' c_bold='' c_note='' c_warn='' c_root='' c_off=''
  local -a numbered=()
  # Amber heading/[note], red [warn], blue root; honor NO_COLOR / non-TTY.
  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    c_amber=$'\033[38;5;214m'
    c_bold=$'\033[1m'
    c_note=$'\033[38;5;214m'
    c_warn=$'\033[31m'
    c_root=$'\033[34m'
    c_off=$'\033[0m'
  fi
  printf '%s' "$c_amber"
  cat <<'EOF'

               _                    _
   _ __   ___| |_ _ __   __ _  ___| | __
  | '_ \ / _ \ __| '_ \ / _` |/ __| |/ /
  | | | |  __/ |_| |_) | (_| | (__|   <
  |_| |_|\___|\__| .__/ \__,_|\___|_|\_\
                 |_|
EOF
  echo
  printf "  netpack (npk)   v%s\n" "$(netpack_version)"
  printf '%s' "$c_off"
  echo
  for t in "${TOOLS[@]}"; do
    [[ "$t" == doctor ]] && continue
    numbered+=("$t")
    st="$(sudo_tag "$t")"
    it="$(impact_tag "$t")"
    c_tag=$c_note
    [[ "$it" == "[warn]" ]] && c_tag=$c_warn
    printf "  %2d) %s%-10s%s  %-6s %s%-6s%s    %s\n" \
      "$i" \
      "$c_bold" "$t" "$c_off" \
      "$st" \
      "$c_tag" "$it" "$c_off" \
      "$(describe "$t")"
    i=$((i + 1))
  done
  echo
  printf "  %2s) %s%-10s%s  %-6s %-6s    %s\n" \
    d \
    "$c_bold" "doctor" "$c_off" \
    "" \
    "" \
    "$(describe doctor)"
  printf "  %2s) %s%-10s%s  %-6s %-6s    %s\n" \
    q \
    "$c_bold" "quit" "$c_off" \
    "" \
    "" \
    "Exit"
  echo
  if [[ "$(id -u)" -eq 0 ]]; then
    printf '  [sudo]    %srunning as root!%s\n' "$c_root" "$c_off"
  else
    printf '  [sudo]    needs root (you are not root)\n'
  fi
  printf '  %s[note]%s    light diagnostic traffic\n' "$c_note" "$c_off"
  printf '  %s[warn]%s    significant load or active probing — planned tests only\n' "$c_warn" "$c_off"
  echo
  printf '%s  Select option (q to quit): %s' "$c_amber" "$c_off"
  if ! read -r sel; then
    echo >&2
    exit 1
  fi
  case "$sel" in
    q|Q|quit|QUIT|cancel|CANCEL|"")
      echo
      printf '%sBye!%s\n' "$c_amber" "$c_off"
      exit 0
      ;;
  esac
  echo
  case "$sel" in
    d|D|doctor)
      run_tool_from_menu doctor
      ;;
  esac
  if [[ "$sel" =~ ^[0-9]+$ ]]; then
    # 10# guards against leading zeros being read as octal
    sel=$((10#$sel))
    if (( sel < 1 || sel > ${#numbered[@]} )); then
      echo "error: invalid selection" >&2
      exit 1
    fi
    run_tool_from_menu "${numbered[$((sel - 1))]}"
  fi
  for t in "${TOOLS[@]}"; do
    if [[ "$sel" == "$t" ]]; then
      run_tool_from_menu "$t"
    fi
  done
  echo "error: unknown tool: ${sel}" >&2
  echo "hint: run 'netpack list'" >&2
  exit 1
}

main() {
  if [[ $# -eq 0 ]]; then
    menu
  fi
  case "$1" in
    help|-h|--help)
      usage
      ;;
    -V|--version)
      local c_amber='' c_off=''
      if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
        c_amber=$'\033[38;5;214m'
        c_off=$'\033[0m'
      fi
      printf '%snetpack (npk)   v%s%s\n' "$c_amber" "$(netpack_version)" "$c_off"
      ;;
    list|ls)
      list_tools
      ;;
    *)
      local name=$1
      shift
      local t
      for t in "${TOOLS[@]}"; do
        if [[ "$name" == "$t" ]]; then
          run_tool "$t" "$@"
        fi
      done
      echo "error: unknown tool: ${name}" >&2
      echo "hint: run 'netpack list'" >&2
      exit 1
      ;;
  esac
}

main "$@"
